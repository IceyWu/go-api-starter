# Development Environment
APP_ENV=development
SERVER_MODE=debug
LOG_LEVEL=debug

# Database (use SQLite for zero-config; switch to mysql / postgres as needed)
DB_DRIVER=sqlite
DB_PATH=./data.db

# Redis (optional — keep disabled in local dev if you don't have Redis running)
REDIS_ENABLED=false
REDIS_HOST=localhost
REDIS_PORT=6379

# API Docs Basic Auth
DOCS_USER=admin
DOCS_PASSWORD=admin123

# JWT
JWT_SECRET=dev-jwt-secret-please-change-for-real-deployments
ACCESS_TOKEN_DAYS=7
REFRESH_TOKEN_DAYS=30

# Default admin (leave empty to skip auto-creation)
ADMIN_EMAIL=
ADMIN_PASSWORD=123456

# OSS — fill in to enable upload features
ALICLOUD_OSS_ENDPOINT=
ALICLOUD_OSS_BUCKET=
ALICLOUD_OSS_REGION=oss-cn-hangzhou
ALICLOUD_ACCESS_KEY_ID=
ALICLOUD_ACCESS_KEY_SECRET=
ALICLOUD_OSS_UPLOAD_DIR=go_oss
