# Application Environment
APP_ENV=development

# Server Configuration
SERVER_HOST=localhost
SERVER_PORT=9527
SERVER_MODE=debug

# Database
# DB_DRIVER: sqlite | mysql | postgres
DB_DRIVER=sqlite
DB_PATH=./data.db

# MySQL example (uncomment when using MySQL)
# DB_DRIVER=mysql
# DB_HOST=localhost
# DB_PORT=3306
# DB_USER=root
# DB_PASSWORD=change-me
# DB_NAME=go_api_starter

# Log Configuration
LOG_LEVEL=debug
LOG_FORMAT=console
LOG_OUTPUT=stdout

# Redis (optional - enables token blacklist, distributed rate limit, cache)
REDIS_ENABLED=false
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_POOL_SIZE=10
REDIS_CLUSTER_MODE=false
REDIS_ENABLE_FALLBACK=true

# API Docs (Swagger / Scalar) Basic Auth
DOCS_USER=admin
DOCS_PASSWORD=change-me

# JWT (at least 32 characters for production)
JWT_SECRET=change-me-to-a-long-random-string
ACCESS_TOKEN_DAYS=7
REFRESH_TOKEN_DAYS=30

# Default admin (leave ADMIN_EMAIL empty to skip auto-creation)
ADMIN_EMAIL=
ADMIN_PASSWORD=change-me

# OSS (Aliyun OSS, optional — fill in to enable upload features)
ALICLOUD_OSS_ENDPOINT=your-bucket.oss-cn-hangzhou.aliyuncs.com
ALICLOUD_OSS_BUCKET=your-bucket
ALICLOUD_OSS_REGION=oss-cn-hangzhou
ALICLOUD_ACCESS_KEY_ID=
ALICLOUD_ACCESS_KEY_SECRET=
ALICLOUD_OSS_UPLOAD_DIR=go_oss
OSS_DOMAIN=
